{
  "name": "sns-audit",
  "version": "2.0.0",
  "description": "Social media content audit and risk classification tool",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./twitter": "./src/platforms/twitter/index.js",
    "./tiktok": "./src/platforms/tiktok/index.js",
    "./reddit": "./src/platforms/reddit/index.js",
    "./threads": "./src/platforms/threads/index.js",
    "./pixiv": "./src/platforms/pixiv/index.js",
    "./naver": "./src/platforms/naver/index.js",
    "./youtube": "./src/platforms/youtube/index.js",
    "./classify": "./src/classifier/index.js"
  },
  "bin": {
    "sns-audit": "./bin/cli.js",
    "sns-audit-tui": "./bin/tui.js"
  },
  "files": [
    "bin/",
    "src/"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "cli":       "node bin/cli.js",
    "tui":       "node bin/tui.js",
    "build:tui": "node scripts/build-tui.js",
    "dev:tui":   "node scripts/build-tui.js --watch"
  },
  "dependencies": {
    "cloakbrowser": "latest",
    "commander": "^14.0.3",
    "glob": "^13.0.6",
    "googleapis": "^171.4.0",
    "ink": "^7.0.3",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "openai": "^6.38.0",
    "playwright-core": "latest",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
